# .gitignore for Google Apps Script projects
# Ignore node_modules if using clasp with npm modules
node_modules/

# Ignore clasp's local settings
.clasp.json

# Ignore Mac system files
.DS_Store

# Ignore log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore VS Code settings
.vscode/

# Ignore build artifacts (if any)
dist/
build/

# Ignore package lock files (optional, if not needed)
# package-lock.json
yarn.lock

# Ignore credentials or secrets
.env
.env.*

# Ignore backup files
*~
*.swp

# Do NOT ignore Apps Script source files
!appsscript.json
!Code.js
